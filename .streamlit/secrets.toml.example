# Configuración de Supabase
SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_KEY = "your-supabase-anon-key"

# APIs de Deportes
API_FOOTBALL_KEY = "your-api-football-key"

# APIs de IA y Pagos
GOOGLE_STUDIO_KEY= "your-gemini-google-studio-key"

# Base de datos PostgreSQL para Prisma
POSTGRES_HOST = "localhost"
POSTGRES_PORT = 5432
POSTGRES_DB = "futdb"
POSTGRES_USER = "postgres"
POSTGRES_PASSWORD = "your-password"
DATABASE_URL = "postgresql://postgres:your-password@localhost:5432/futdb"

# Configuración opcional
LOG_LEVEL = "info"
DEBUG_MODE = false
